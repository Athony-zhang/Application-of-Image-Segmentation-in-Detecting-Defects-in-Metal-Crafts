# Core functions for split-and-merge segmentation
def split_image(image, x, y, w, h, threshold, regions):
    sub_img = image[y:y+h, x:x+w]
    var = np.var(sub_img)
    mean = np.mean(sub_img)
    
    if (w <= 6 or h <= 6) or (var < threshold):
        regions.append((x, y, w, h, mean, var))
        return
    
    w2, h2 = w//2, h//2
    split_image(image, x, y, w2, h2, threshold, regions)
    split_image(image, x+w2, y, w - w2, h2, threshold, regions)
    split_image(image, x, y+h2, w2, h - h2, threshold, regions)
    split_image(image, x+w2, y+h2, w - w2, h - h2, threshold, regions)


def merge_regions(image, regions, diff_threshold):
    merged = []
    used = [False] * len(regions)
    
    for i in range(len(regions)):
        if used[i]:
            continue
        x1, y1, w1, h1, m1, v1 = regions[i]
        current = [i]
        
        for j in range(i+1, len(regions)):
            if used[j]:
                continue
            x2, y2, w2, h2, m2, v2 = regions[j]
            
            is_adjacent = (
                (x1 + w1 == x2 or x2 + w2 == x1) and 
                (y1 < y2 + h2 and y2 < y1 + h1)
            ) or (
                (y1 + h1 == y2 or y2 + h2 == y1) and 
                (x1 < x2 + w2 and x2 < x1 + w1)
            )
            
            if is_adjacent and abs(m1 - m2) < diff_threshold:
                current.append(j)
                m1 = (m1 * (w1*h1) + m2 * (w2*h2)) / (w1*h1 + w2*h2)
                w1 = max(x1 + w1, x2 + w2) - min(x1, x2)
                h1 = max(y1 + h1, y2 + h2) - min(y1, y2)
                x1 = min(x1, x2)
                y1 = min(y1, y2)
        
        for idx in current:
            used[idx] = True
        merged.append((x1, y1, w1, h1, m1))
    
    return merged


def segment_with_split_merge(image, split_threshold=250, merge_threshold=85):
    h, w = image.shape
    regions = []
    split_image(image, 0, 0, w, h, split_threshold, regions)
    merged_regions = merge_regions(image, regions, merge_threshold)
    return merged_regions

# Merge bounding boxes based on distance (to resolve duplicate detections)
def merge_boxes_by_distance(boxes, distance_thresh=50):
    if not boxes:
        return []
    
    # Calculate the center coordinates of each box
    centers = []
    for (x, y, w, h, mean) in boxes:
        cx = x + w / 2
        cy = y + h / 2
        centers.append((cx, cy, x, y, w, h, mean))
    
    # Clustering (group boxes with center distance below the threshold)
    clusters = []
    used = [False] * len(centers)
    
    for i in range(len(centers)):
        if used[i]:
            continue
        cx1, cy1, x1, y1, w1, h1, m1 = centers[i]
        cluster = [(x1, y1, w1, h1, m1)]
        used[i] = True
        
        for j in range(len(centers)):
            if used[j]:
                continue
            cx2, cy2, x2, y2, w2, h2, m2 = centers[j]
            # Calculate center distance
            dist = np.sqrt((cx1 - cx2)**2 + (cy1 - cy2)**2)
            if dist < distance_thresh:
                cluster.append((x2, y2, w2, h2, m2))
                used[j] = True
        
        # For boxes in the same cluster, find the minimum bounding rectangle
        xs = []
        ys = []
        for (x, y, w, h, mean) in cluster:
            xs.append(x)
            xs.append(x + w)
            ys.append(y)
            ys.append(y + h)
        min_x = min(xs)
        max_x = max(xs)
        min_y = min(ys)
        max_y = max(ys)
        merged_w = max_x - min_x
        merged_h = max_y - min_y
        # Use the mean of the first box in the cluster as the merged mean
        merged_mean = cluster[0][4]
        clusters.append((min_x, min_y, merged_w, merged_h, merged_mean))
    
    return clusters

# Execute split-and-merge segmentation
merged_regions = segment_with_split_merge(img_corrected, split_threshold=255, merge_threshold=85)

aluminum_mean = np.mean(img_corrected)
print(f"Average grayscale value of the aluminum sheet: {aluminum_mean:.2f}")

defect_regions = []
min_defect_area = 500
gray_thresh = 40

for (x, y, w, h, mean) in merged_regions:
    area = w * h
    if mean < aluminum_mean - gray_thresh and area > min_defect_area:
        defect_regions.append((x, y, w, h, mean))

print(f"Initial number of detected defects: {len(defect_regions)}")

defect_regions_merged = merge_boxes_by_distance(defect_regions, distance_thresh=60)
print(f"Number of defects after merging: {len(defect_regions_merged)}")

# Visualization
img_color = cv2.cvtColor(img_corrected, cv2.COLOR_GRAY2BGR)

for (x, y, w, h, mean) in defect_regions_merged:
    cv2.rectangle(img_color, (int(x), int(y)), (int(x+w), int(y+h)), (0, 0, 255), 2)
    cv2.putText(img_color, f"Defect", (int(x), int(y)-5), 
                cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0,0,255), 1)

