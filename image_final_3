# Illumination correction
kernel_size = (151, 151)
background = cv2.GaussianBlur(img_denoised, kernel_size, sigmaX=0)

mean_bg = np.mean(background)
img_corrected = cv2.addWeighted(src1=img_denoised, alpha=1.0,
                                src2=background, beta=-1.0,
                                gamma=mean_bg)

img_corrected = cv2.normalize(img_corrected, None, 
                              alpha=0, beta=255, 
