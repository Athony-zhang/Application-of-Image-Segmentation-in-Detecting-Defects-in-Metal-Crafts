import cv2
import numpy as np
import matplotlib.pyplot as plt
import os

# Folder containing images to be detected
input_folder = r"D:/Code/Image/Defect/2"
# Folder to save detection results (will be created automatically if it does not exist)
output_folder = r"D:/Code/Image/Defect/2/Detect_Result"

# Create the result folder if it doesn't exist
if not os.path.exists(output_folder):
    os.makedirs(output_folder)

# Cache the first 9 detection result images for later combined display
show_imgs = []
max_show_num = 9  # Fixed to take the first 9 images

# Functions
def split_image(image, x, y, w, h, threshold, regions):
    sub_img = image[y:y+h, x:x+w]
    var = np.var(sub_img)
    mean = np.mean(sub_img)
    
    if (w <= 6 or h <= 6) or (var < threshold):
        regions.append((x, y, w, h, mean, var))
        return
    
    w2, h2 = w//2, h//2
    split_image(image, x, y, w2, h2, threshold, regions)
    split_image(image, x+w2, y, w - w2, h2, threshold, regions)
    split_image(image, x, y+h2, w2, h - h2, threshold, regions)
    split_image(image, x+w2, y+h2, w - w2, h - h2, threshold, regions)


def merge_regions(image, regions, diff_threshold):
    merged = []
    used = [False] * len(regions)
    for i in range(len(regions)):
        if used[i]:
            continue
        x1, y1, w1, h1, m1, v1 = regions[i]
        current = [i]
        for j in range(i+1, len(regions)):
            if used[j]:
                continue
            x2, y2, w2, h2, m2, v2 = regions[j]
            is_adjacent = (
                (x1 + w1 == x2 or x2 + w2 == x1) and
                (y1 < y2 + h2 and y2 < y1 + h1)
            ) or (
                (y1 + h1 == y2 or y2 + h2 == y1) and
                (x1 < x2 + w2 and x2 < x1 + w1)
            )
            if is_adjacent and abs(m1 - m2) < diff_threshold:
                current.append(j)
                m1 = (m1 * (w1*h1) + m2 * (w2*h2)) / (w1*h1 + w2*h2)
                w1 = max(x1 + w1, x2 + w2) - min(x1, x2)
                h1 = max(y1 + h1, y2 + h2) - min(y1, y2)
                x1 = min(x1, x2)
                y1 = min(y1, y2)
        for idx in current:
            used[idx] = True
        merged.append((x1, y1, w1, h1, m1))
    return merged


def segment_with_split_merge(image, split_threshold=250, merge_threshold=85):
    h, w = image.shape
    regions = []
    split_image(image, 0, 0, w, h, split_threshold, regions)
    merged_regions = merge_regions(image, regions, merge_threshold)
    return merged_regions


def merge_boxes_by_distance(boxes, distance_thresh=60):
    if not boxes:
        return []
    centers = []
    for (x, y, w, h, mean) in boxes:
        cx = x + w / 2
        cy = y + h / 2
        centers.append((cx, cy, x, y, w, h, mean))
    clusters = []
    used = [False] * len(centers)
    for i in range(len(centers)):
        if used[i]:
            continue
        cx1, cy1, x1, y1, w1, h1, m1 = centers[i]
        cluster = [(x1, y1, w1, h1, m1)]
        used[i] = True
        for j in range(len(centers)):
            if used[j]:
                continue
            cx2, cy2, x2, y2, w2, h2, m2 = centers[j]
            dist = np.sqrt((cx1 - cx2)**2 + (cy1 - cy2)**2)
            if dist < distance_thresh:
                cluster.append((x2, y2, w2, h2, m2))
                used[j] = True
        xs, ys = [], []
        for (x, y, w, h, mean) in cluster:
            xs.append(x)
            xs.append(x + w)
            ys.append(y)
            ys.append(y + h)
        min_x, max_x = min(xs), max(xs)
        min_y, max_y = min(ys), max(ys)
        merged_w = max_x - min_x
        merged_h = max_y - min_y
        merged_mean = cluster[0][4]
        clusters.append((min_x, min_y, merged_w, merged_h, merged_mean))
    return clusters

# Batch iterate through images and perform detection
# Supported image extensions
img_suffix = ('.jpg', '.jpeg', '.png', '.bmp')

for file_name in os.listdir(input_folder):
    # Stop caching once 9 images are reached
    if len(show_imgs) >= max_show_num:
        pass
    
    # Filter image files
    if file_name.lower().endswith(img_suffix):
        img_path = os.path.join(input_folder, file_name)
        print(f"Processing: {file_name}")

        # Read image in grayscale
        img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)
        if img is None:
            print(f"Warning: Unable to read {file_name}, skipping")
            continue

        # Histogram equalization
        img_eq = cv2.equalizeHist(img)
        # Gaussian blur for denoising
        img_denoised = cv2.GaussianBlur(img_eq, (5, 5), sigmaX=1.0)

        # Illumination correction
        kernel_size = (151, 151)
        background = cv2.GaussianBlur(img_denoised, kernel_size, sigmaX=0)
        mean_bg = np.mean(background)
        img_corrected = cv2.addWeighted(img_denoised, 1.0, background, -1.0, mean_bg)
        img_corrected = cv2.normalize(img_corrected, None, 0, 255, cv2.NORM_MINMAX)
        img_corrected = img_corrected.astype(np.uint8)

        # Split-and-merge segmentation
        merged_regions = segment_with_split_merge(img_corrected)

        # Defect filtering
        aluminum_mean = np.mean(img_corrected)
        min_defect_area = 500
        gray_thresh = 40
        defect_regions = []
        for (x, y, w, h, mean) in merged_regions:
            area = w * h
            if mean < aluminum_mean - gray_thresh and area > min_defect_area:
                defect_regions.append((x, y, w, h, mean))

        # Merge duplicate bounding boxes based on distance
        defect_regions_merged = merge_boxes_by_distance(defect_regions, distance_thresh=60)

        # Draw detection bounding boxes
        img_color = cv2.cvtColor(img_corrected, cv2.COLOR_GRAY2BGR)
        for (x, y, w, h, mean) in defect_regions_merged:
            cv2.rectangle(img_color, (int(x), int(y)), (int(x+w), int(y+h)), (0, 0, 255), 2)
            cv2.putText(img_color, "Defect", (int(x), int(y)-5),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, (0, 0, 255), 1)

        # Cache the first 9 result images
        if len(show_imgs) < max_show_num:
            show_imgs.append(cv2.cvtColor(img_color, cv2.COLOR_BGR2RGB))

        # Save the detection result
        save_path = os.path.join(output_folder, file_name)
        cv2.imwrite(save_path, img_color)

print("=" * 40)
print("All images have been processed! Results saved to:", output_folder)

# Display the combined results of the first 9 images
plt.figure(figsize=(15, 12))  # Canvas size, adjustable as needed
for idx in range(len(show_imgs)):
    plt.subplot(3, 3, idx + 1)
    plt.imshow(show_imgs[idx])
    plt.title(f"Sample {idx+1}", fontsize=10)
    plt.axis("off")  # Hide axes

plt.tight_layout()
plt.show()
